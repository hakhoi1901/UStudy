# -----------------------------------------------------------------------------
# USTUY ENVIRONMENT CONFIGURATION
# -----------------------------------------------------------------------------

# AI Provider: 'gemini', 'groq', hoặc 'auto' (Chế độ auto: Thử Gemini trước, nếu bị giới hạn lượt gọi sẽ tự động nhảy sang Groq)
VITE_AI_PROVIDER=auto

# Google Gemini Configuration
# Lấy API Key miễn phí tại: https://aistudio.google.com/
VITE_GEMINI_API_KEY=

# Groq Cloud Configuration
# Lấy API Key miễn phí tại: https://console.groq.com/
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-specdec
